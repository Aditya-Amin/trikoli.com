{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "trikoli/step",
  "version": "1.0.0",
  "title": "Step",
  "category": "trikoli",
  "parent": [ "trikoli/steps" ],
  "icon": "list-view",
  "description": "A single process step: number, title and description.",
  "keywords": [ "step", "process" ],
  "textdomain": "trikoli",
  "supports": { "anchor": true, "html": false, "reusable": false },
  "attributes": {
    "number": { "type": "string", "default": "01" },
    "title": { "type": "string", "default": "" },
    "description": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js"
}
