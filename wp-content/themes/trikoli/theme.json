{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": false,
    "layout": {
      "contentSize": "1290px",
      "wideSize": "1600px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "custom": true,
      "palette": [
        { "slug": "primary", "color": "#2F6BE0", "name": "Primary" },
        { "slug": "primary-dark", "color": "#2057C4", "name": "Primary Dark" },
        { "slug": "primary-light", "color": "#5B9BF5", "name": "Primary Light" },
        { "slug": "navy", "color": "#0B1B4D", "name": "Navy" },
        { "slug": "heading", "color": "#0B1B4D", "name": "Heading" },
        { "slug": "body", "color": "#5B6478", "name": "Body Text" },
        { "slug": "muted", "color": "#9AA3B2", "name": "Muted" },
        { "slug": "light", "color": "#F3F6FF", "name": "Light" },
        { "slug": "surface", "color": "#EEF4FF", "name": "Surface" },
        { "slug": "border", "color": "#E2E8F4", "name": "Border" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" },
        { "slug": "black", "color": "#030712", "name": "Black" }
      ],
      "gradients": [
        { "slug": "brand", "name": "Brand", "gradient": "linear-gradient(135deg, #5B9BF5 0%, #2F6BE0 100%)" },
        { "slug": "brand-soft", "name": "Brand Soft", "gradient": "linear-gradient(180deg, #F3F6FF 0%, #FFFFFF 100%)" }
      ]
    },
    "typography": {
      "fluid": true,
      "customFontSize": true,
      "lineHeight": true,
      "fontFamilies": [
        {
          "slug": "body",
          "name": "Space Grotesk",
          "fontFamily": "\"Space Grotesk\", -apple-system, system-ui, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Space Grotesk",
              "fontWeight": "300 700",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/space-grotesk.woff2" ]
            }
          ]
        },
        {
          "slug": "heading",
          "name": "Urbanist",
          "fontFamily": "\"Urbanist\", -apple-system, system-ui, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Urbanist",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/urbanist.woff2" ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "name": "Small", "size": "0.875rem", "fluid": false },
        { "slug": "medium", "name": "Medium", "size": "1rem", "fluid": false },
        { "slug": "large", "name": "Large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.25rem" } },
        { "slug": "x-large", "name": "X-Large", "size": "2rem", "fluid": { "min": "1.5rem", "max": "2rem" } },
        { "slug": "xx-large", "name": "XX-Large", "size": "3rem", "fluid": { "min": "2.25rem", "max": "3rem" } },
        { "slug": "huge", "name": "Huge", "size": "4rem", "fluid": { "min": "2.75rem", "max": "4.5rem" } }
      ]
    },
    "spacing": {
      "units": [ "px", "em", "rem", "%", "vw", "vh" ],
      "customSpacingSize": true,
      "spacingScale": { "steps": 0 },
      "spacingSizes": [
        { "slug": "20", "name": "1", "size": "0.5rem" },
        { "slug": "30", "name": "2", "size": "1rem" },
        { "slug": "40", "name": "3", "size": "1.5rem" },
        { "slug": "50", "name": "4", "size": "2.5rem" },
        { "slug": "60", "name": "5", "size": "4rem" },
        { "slug": "70", "name": "6", "size": "6rem" },
        { "slug": "80", "name": "7", "size": "8rem" }
      ]
    },
    "border": { "color": true, "radius": true, "style": true, "width": true },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "card", "name": "Card", "shadow": "0 24px 50px -24px rgba(47,107,224,0.35)" },
        { "slug": "soft", "name": "Soft", "shadow": "0 10px 30px -12px rgba(11,27,77,0.12)" }
      ]
    },
    "custom": {
      "radius": { "sm": "10px", "md": "16px", "lg": "22px", "pill": "50px" }
    }
  },
  "styles": {
    "color": { "background": "var:preset|color|white", "text": "var:preset|color|body" },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "0",
      "padding": { "top": "0", "bottom": "0", "left": "0", "right": "0" }
    },
    "elements": {
      "heading": {
        "typography": { "fontFamily": "var:preset|font-family|heading", "fontWeight": "600", "lineHeight": "1.15" },
        "color": { "text": "var:preset|color|heading" }
      },
      "h1": { "typography": { "fontSize": "var:preset|font-size|huge" } },
      "h2": { "typography": { "fontSize": "var:preset|font-size|xx-large" } },
      "h3": { "typography": { "fontSize": "var:preset|font-size|x-large" } },
      "link": {
        "color": { "text": "var:preset|color|primary" },
        ":hover": { "color": { "text": "var:preset|color|primary-dark" } }
      },
      "button": {
        "color": { "background": "var:preset|color|primary", "text": "var:preset|color|white" },
        "border": { "radius": "50px" },
        "spacing": { "padding": { "top": "0.9rem", "bottom": "0.9rem", "left": "1.8rem", "right": "1.8rem" } },
        "typography": { "fontWeight": "600", "fontFamily": "var:preset|font-family|body" },
        ":hover": { "color": { "background": "var:preset|color|primary-dark", "text": "var:preset|color|white" } }
      }
    },
    "blocks": {
      "core/post-title": { "typography": { "fontFamily": "var:preset|font-family|heading" } },
      "core/heading": { "typography": { "fontFamily": "var:preset|font-family|heading" } }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page-full-width", "title": "Full Width Page", "postTypes": [ "page" ] }
  ]
}
